{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_HERE",
    "Issuer": "FertileNotifyAPI",
    "Audience": "FertileNotifyClients",
    "ExpiryInMinutes": 15
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=FertileNotifyDb;Username=postgres;Password=YOUR_DB_PASSWORD_HERE;"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "YOUR_RABBITMQ_USER",
    "Password": "YOUR_RABBITMQ_PASS"
  },
  "SystemSmtp": {
    "Host": "YOUR_SMTP_HOST",
    "Port": 587,
    "Username": "YOUR_SMTP_USER",
    "Password": "YOUR_SMTP_PASS",
    "From": "YOUR_FROM_EMAIL"
  },
  "OTPSettings": {
    "ExpiryInMinutes": "OTP_EXPIRY_IN_MINUTES",
    "Length": "OTP_LENGTH"
  },
  "Security": {
    "UnsubscribeSecret": "YOUR_UNSUBSCRIBE_SECRET"
  }
}