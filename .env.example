# --- Environment ---
ASPNETCORE_ENVIRONMENT=Development
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173

# --- Database (PostgreSQL) ---
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD
DB_NAME=FertileNotifyDb
DB_HOST=localhost
DB_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_HOST=localhost

# --- Smtp ---
SYSTEM_SMTP_HOST="YOUR_SMTP_HOST"
SYSTEM_SMTP_PORT="YOUR_SMTP_PORT"
SYSTEM_SMTP_USERNAME="YOUR_SMTP_USER"
SYSTEM_SMTP_PASSWORD="YOUR_SMTP_PASS"
SYSTEM_SMTP_FROM="YOUR_FROM_EMAIL"

# --- OTP ---
OTP_EXPIRY_IN_MINUTES="YOUR_OTP_EXPIRY_IN_MINUTES"
OTP_LENGTH="YOUR_OTP_LENGTH"

# --- Security ---
JWT_SECRET=YOUR_SUPER_SECRET_KEY_32_CHARS_MIN